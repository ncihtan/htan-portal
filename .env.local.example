# ClickHouse connection settings
# These are used by the Next.js API route (/api/clickhouse) to proxy
# ClickHouse queries from the browser without exposing credentials.
#
# For local development, copy this file to .env.local and fill in the values.
# The defaults below point to the public read-only HTAN ClickHouse instance.

# Full connection URL (host + database).
# If set, takes precedence over CLICKHOUSE_HOST and CLICKHOUSE_DB.
CLICKHOUSE_URL=https://dl96orhu96.us-east-1.aws.clickhouse.cloud:8443/htan_2026_03_17_1826

# Alternatively, set host and database separately:
# CLICKHOUSE_HOST=https://dl96orhu96.us-east-1.aws.clickhouse.cloud:8443
# CLICKHOUSE_DB=htan_2026_03_17_1826

# Read-only user credentials
CLICKHOUSE_USER=htanwebuser
CLICKHOUSE_PASSWORD=your_password_here
