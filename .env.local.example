# ClickHouse connection settings
# These variables are embedded in the client-side bundle at build time
# (via Next.js NEXT_PUBLIC_ prefix) so the browser can query ClickHouse directly.
#
# For local development, copy this file to .env.local and fill in the values.
# The defaults below point to the public read-only HTAN ClickHouse instance.

# ClickHouse host and database (used to construct the connection URL).
NEXT_PUBLIC_CLICKHOUSE_HOST=https://dl96orhu96.us-east-1.aws.clickhouse.cloud:8443
NEXT_PUBLIC_CLICKHOUSE_DB=htan_2026_03_17_1826

# Alternatively, set a full connection URL (overrides HOST and DB above):
# NEXT_PUBLIC_CLICKHOUSE_URL=https://dl96orhu96.us-east-1.aws.clickhouse.cloud:8443/htan_2026_03_17_1826

# Read-only user credentials
NEXT_PUBLIC_CLICKHOUSE_USER=htanwebuser
NEXT_PUBLIC_CLICKHOUSE_PASSWORD=YOUR_READ_ONLY_PASSWORD_HERE
